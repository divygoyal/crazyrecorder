{
  "name": "@yourbrand/chrome-extension",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc --noEmit && vite build && node -e \"const fs=require('fs');fs.cpSync('manifest.json','dist/manifest.json');fs.cpSync('public/icons','dist/icons',{recursive:true})\"",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "idb-keyval": "^6.2.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "typescript": "^5.7.3",
    "vite": "^5.4.21",
    "tailwindcss": "^3.4.17",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3"
  }
}
